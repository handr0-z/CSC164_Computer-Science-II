<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.shape.Circle?>

<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.javafx.CircleSizeController">
   <center>
      <StackPane prefHeight="150.0" prefWidth="200.0" BorderPane.alignment="CENTER">
         <children>
            <Circle fx:id="myCircle" fill="#65da58" radius="100.0" stroke="BLACK" strokeType="INSIDE" />
         </children>
      </StackPane>
   </center>
   <bottom>
      <HBox prefHeight="100.0" prefWidth="200.0" BorderPane.alignment="CENTER">
         <children>
            <Button fx:id="shrinkButton" mnemonicParsing="false" onAction="#onShrinkButtonClick" text="Shrink" translateX="246.0" />
            <Button fx:id="enlargeButton" mnemonicParsing="false" onAction="#onEnlargeButtonClick" text="Enlarge" translateX="246.0" />
         </children>
      </HBox>
   </bottom>
</BorderPane>
