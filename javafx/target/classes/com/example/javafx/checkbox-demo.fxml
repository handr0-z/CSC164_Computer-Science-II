<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="20.0" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/23.0.1" fx:controller="com.example.javafx.CheckboxDemoController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
   <HBox alignment="CENTER" prefHeight="100.0" prefWidth="200.0" spacing="20.0">
      <children>
         <CheckBox fx:id="checkBox1" mnemonicParsing="false" onAction="#onCheckBox1Click" text="Check Box 1" />
         <CheckBox fx:id="checkBox2" mnemonicParsing="false" onAction="#onCheckBox2Click" text="Check Box 2" />
      </children>
   </HBox>
    <Button fx:id="orderButton" onAction="#onOrderButtonClick" text="Order" />
</VBox>
